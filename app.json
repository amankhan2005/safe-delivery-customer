{
  "expo": {
    "name": "Safe Delivery",
    "slug": "safe-delivery-customer",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4FD8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.safedelivery.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Safe Delivery needs your location to find nearby riders and calculate delivery routes.",
        "NSLocationAlwaysUsageDescription": "Safe Delivery uses location for delivery tracking."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B4FD8"
      },
      "package": "com.safedelivery.customer",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "allowBackup": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Safe Delivery to use your location to find riders and calculate routes."
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-splash-screen",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.21"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f2e13922-554e-4a3d-ac17-ef52528a19f9"
      }
    },
    "owner": "safedelivery"
  }
}
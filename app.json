{
  "expo": {
    "name": "Safe Delivery",
    "slug": "safe-delivery-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4FD8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.safedelivery.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Safe Delivery needs your location to find nearby riders and calculate delivery routes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B4FD8"
      },
      "package": "com.safedelivery.customer",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Safe Delivery to use your location to find riders and calculate routes."
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "f2e13922-554e-4a3d-ac17-ef52528a19f9"
      }
    }
  }
}
